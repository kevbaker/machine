# Brewfile for macOS machine setup

# Taps
tap "homebrew/bundle"
tap "homebrew/cask"
tap "homebrew/core"

# Development tools
brew "git"
brew "nvm"
brew "pyenv"
brew "pipx"

# Container & virtualization
brew "podman"

# Editors & IDEs
cask "visual-studio-code"

# Terminal
cask "warp"

# Utilities
brew "wget"
brew "curl"
brew "jq"

# Optional: Mac App Store CLI
brew "mas"
